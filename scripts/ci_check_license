#!/usr/bin/env bash
#
# This script exits non-zero if the LICENSE file's third-party section is out of sync
# with the actual vendor license files.
set -eu -o pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
cd "${repo_root}"

LICENSE_FILE="LICENSE"

# Get expected licenses from vendor directory
expected_licenses=$(find vendor -name "LICENSE*" -type f | sort)

# Get licenses listed in LICENSE file (lines starting with "    vendor/")
listed_licenses=$(grep -E "^    vendor/" "$LICENSE_FILE" 2>/dev/null | sed 's/^    //' | sort || true)

# Compare
if [ "$expected_licenses" != "$listed_licenses" ]; then
    echo "ERROR: LICENSE file third-party section is out of sync with vendor licenses."
    echo ""
    echo "Expected licenses not in LICENSE file:"
    comm -23 <(echo "$expected_licenses") <(echo "$listed_licenses") | head -20
    echo ""
    echo "Licenses in LICENSE file but not in vendor:"
    comm -13 <(echo "$expected_licenses") <(echo "$listed_licenses") | head -20
    echo ""
    echo "Run 'make license-update' to fix this."
    exit 1
fi

if [ -z "$expected_licenses" ]; then
    license_count=0
else
    license_count=$(printf '%s\n' "$expected_licenses" | grep -c '.')
fi

echo "LICENSE file third-party section is up to date ($license_count licenses)."
