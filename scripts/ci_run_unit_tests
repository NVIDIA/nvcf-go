#! /usr/bin/env bash
#
# Runs unit tests, strips generated files from the coverage profile, and
# checks the coverage threshold.
set -eu -o pipefail

CI_PROJECT_DIR=${CI_PROJECT_DIR:-"_output"}
EGX_GO_TEST_RESULTS_DIR=${EGX_GO_TEST_RESULTS_DIR:-"${CI_PROJECT_DIR}/go-tests"}

# Run tests and produce coverage profile.
make test

# Strip generated files from the coverage profile so they don't drag down
# the reported percentage.
grep -v 'zz_generated' "${EGX_GO_TEST_RESULTS_DIR}/cover.txt" > "${EGX_GO_TEST_RESULTS_DIR}/cover_filtered.txt"
mv "${EGX_GO_TEST_RESULTS_DIR}/cover_filtered.txt" "${EGX_GO_TEST_RESULTS_DIR}/cover.txt"

# Regenerate the HTML report from the filtered profile.
go tool cover -html="${EGX_GO_TEST_RESULTS_DIR}/cover.txt" -o "${EGX_GO_TEST_RESULTS_DIR}/cover.html"

# Check the threshold against the filtered profile.
# Coverage threshold: 85%
COVERAGE_THRESHOLD=85

# Original nv_ci_check_coverage command (commented out for now, can be restored later)
# nv_ci_check_coverage

# Check coverage manually with threshold of 65
coverage=$(go tool cover -func="${EGX_GO_TEST_RESULTS_DIR}/cover.txt" | grep total: | awk '{print $3}' | sed 's/%//')
coverage_int=$(echo "$coverage" | awk -F '.' '{print $1}')
echo "Test coverage threshold: ${COVERAGE_THRESHOLD}"
echo "Actual average coverage: ${coverage}"
if [ "$coverage_int" -lt "$COVERAGE_THRESHOLD" ]; then
	echo "FAIL: actual test coverage is BELOW threshold."
	exit 1
else
	echo "PASS: actual test coverage meets threshold."
fi
